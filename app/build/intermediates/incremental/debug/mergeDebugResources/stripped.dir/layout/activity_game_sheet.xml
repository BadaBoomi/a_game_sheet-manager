<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fitsSystemWindows="true">

    <!-- Main drawing area fills the whole screen -->
    <ImageView
        android:id="@+id/ivTemplateBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="@string/template_background_desc" />

    <de.badaboomi.gamesheetmanager.ui.game.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <LinearLayout
        android:id="@+id/floatingControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/btnMenuHandle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="10dp"
            android:src="@drawable/ic_color_circle"
            android:background="@drawable/bg_floating_menu"
            android:contentDescription="@string/btn_floating_menu"
            android:elevation="8dp"
            app:tint="@android:color/black" />

        <ImageButton
            android:id="@+id/btnQuickUndo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_undo"
            android:background="@drawable/bg_floating_menu"
            android:contentDescription="@string/btn_undo"
            android:elevation="8dp"
            app:tint="@android:color/black" />

    </LinearLayout>

</FrameLayout>
